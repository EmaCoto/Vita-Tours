---
import Layout from '../../layouts/Layout.astro'; // Asegúrate de que la ruta sea correcta
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const blogEntries = await getCollection('blogs');
  return blogEntries.map(entry => ({
    params: { slug: entry.slug }, props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await entry.render();
---

<Layout title={entry.data.title}>
  <article class="bg-white min-h-screen pb-32">
    <header class="relative w-full h-[70vh] flex items-center justify-center overflow-hidden bg-gray-950">
      <img 
        src={entry.data.image} 
        alt={entry.data.title}
        class="absolute inset-0 w-full h-full object-cover opacity-50 scale-110 hero-img"
      />
      <div class="absolute inset-0 bg-gradient-to-b from-black/40 via-transparent to-white"></div>
      
      <div class="relative z-10 max-w-5xl px-6 text-center reveal-header">
        <span class="inline-block px-4 py-1 mb-6 text-[10px] font-black uppercase italic tracking-[0.3em] bg-[#38F5C4] text-black">
          {entry.data.category}
        </span>
        <h1 class="text-5xl md:text-8xl lg:text-9xl font-black uppercase italic text-white leading-[0.8] tracking-tighter">
          {entry.data.title.split(' ').map((word, i) => (
            <span class="inline-block overflow-hidden">
               <span class="inline-block transform-word">{word}&nbsp;</span>
            </span>
          ))}
        </h1>
      </div>

      <div class="absolute right-10 bottom-20 hidden lg:block overflow-hidden">
        <span class="text-white/30 text-[10px] font-black uppercase tracking-[0.5em] rotate-90 inline-block origin-right">SCROLL TO READ</span>
      </div>
    </header>

    <div class="max-w-4xl mx-auto px-6 -mt-32 relative z-20">
      <div class="bg-white p-10 md:p-20 rounded-[3rem] shadow-[0_50px_100px_-20px_rgba(0,0,0,0.1)] border border-gray-50 post-content">
        
        <div class="flex flex-wrap items-center gap-4 mb-12 pb-8 border-b border-gray-100">
           <div class="w-10 h-10 rounded-full bg-[#36AAF5] flex items-center justify-center text-white font-black italic">
             {entry.data.author.charAt(0)}
           </div>
           <div>
             <p class="text-[10px] font-black uppercase tracking-widest text-gray-900">{entry.data.author}</p>
             <p class="text-[9px] font-bold text-gray-400 uppercase tracking-widest">
               {entry.data.date.toLocaleDateString('es-ES', { day: '2-digit', month: 'long', year: 'numeric' })}
             </p>
           </div>
        </div>

        <div class="prose prose-xl prose-gray max-w-none 
          prose-headings:font-black prose-headings:uppercase prose-headings:italic prose-headings:tracking-tighter prose-headings:text-gray-900
          prose-h2:text-4xl md:prose-h2:text-5xl prose-h2:mt-16
          prose-p:text-gray-600 prose-p:leading-[1.7] prose-p:mb-8
          prose-strong:text-black prose-strong:font-black
          prose-blockquote:border-l-8 prose-blockquote:border-[#38F5C4] prose-blockquote:bg-gray-50 prose-blockquote:py-8 prose-blockquote:px-10 prose-blockquote:rounded-2xl prose-blockquote:not-italic prose-blockquote:font-black prose-blockquote:text-2xl prose-blockquote:text-gray-900
          ">
          <Content />
        </div>

        <footer class="mt-24 pt-12 border-t border-gray-100 flex flex-col items-center">
          <p class="text-xs font-black uppercase italic tracking-widest text-gray-400 mb-8">¿Listo para el siguiente paso?</p>
          <a href="/blogs" class="group relative px-10 py-5 bg-black text-white overflow-hidden rounded-full transition-all">
             <span class="relative z-10 font-black uppercase italic tracking-widest text-xs">Volver a la bitácora</span>
             <div class="absolute inset-0 bg-[#36AAF5] translate-y-full group-hover:translate-y-0 transition-transform duration-500"></div>
          </a>
        </footer>
      </div>
    </div>
  </article>
</Layout>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";
  gsap.registerPlugin(ScrollTrigger);

  // Animación de entrada: Revelado de palabras
  gsap.from(".transform-word", {
    y: 150,
    rotate: 5,
    duration: 1.2,
    stagger: 0.1,
    ease: "power4.out"
  });

  // Parallax en la imagen hero
  gsap.to(".hero-img", {
    scrollTrigger: {
      trigger: "header",
      start: "top top",
      end: "bottom top",
      scrub: true
    },
    y: 100,
    scale: 1.3
  });

  // Fade in de los bloques de contenido mientras haces scroll
  const paragraphs = document.querySelectorAll(".prose > *");
  paragraphs.forEach((p) => {
    gsap.from(p, {
      scrollTrigger: {
        trigger: p,
        start: "top 90%",
        toggleActions: "play none none reverse"
      },
      y: 30,
      opacity: 0,
      duration: 0.8,
      ease: "power2.out"
    });
  });
</script>

<style is:global>
  /* Suavizado de scroll */
  html { scroll-behavior: smooth; }
  
  /* Ajuste de selección de texto con colores de marca */
  ::selection {
    background-color: #38F5C4;
    color: black;
  }
</style>