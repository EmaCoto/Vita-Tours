---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const posts = await getCollection('blogs'); 
const sortedPosts = posts.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const featuredPost = sortedPosts[0];
const remainingPosts = sortedPosts.slice(1);
---

<Layout title="Bitácora | Psicología Activa">
  <main class="bg-gray-100">
    
    <section class="relative pt-32 pb-20 px-6">
      <div class="max-w-7xl mx-auto flex flex-col md:flex-row md:items-end justify-between gap-10 relative z-10 px-6">
        <div class="reveal-header max-w-2xl">
          <span class="text-[#36AAF5] font-black uppercase tracking-[0.4em] text-[10px] block mb-6 italic">Exploración Humana</span>
          <h1 class="text-4xl md:text-6xl font-black uppercase italic text-gray-900 leading-[0.85] tracking-tighter">
            CIENCIA <br/> <span class="text-[#38F5C4]">& AVENTURA</span>
          </h1>
        </div>
        
        <div class="reveal-header-right text-right hidden md:block">
          <p class="text-[10px] font-black uppercase tracking-[0.2em] text-gray-400 mb-2">Artículos Publicados</p>
          <div class="text-5xl font-black italic text-gray-900 tracking-tighter">
            {posts.length < 10 ? `0${posts.length}` : posts.length}
          </div>
          <div class="w-24 h-1 bg-[#38F5C4] ml-auto mt-4"></div>
        </div>
      </div>
    </section>

    {featuredPost && (
      <section class="py-5 px-6 max-w-7xl mx-auto">
        <div class="featured-card group relative rounded-lg p-6 lg:p-10 transition-all duration-500 hover:bg-white hover:shadow-2xl border border-gray-100">
          <a href={`/blogs/${featuredPost.slug}`} class="absolute inset-0 z-30" aria-label={featuredPost.data.title}></a>
          
          <div class="flex flex-col lg:flex-row items-center gap-12 relative z-10">
            <div class="w-full lg:w-3/5 aspect-video overflow-hidden rounded-lg shadow-xl">
              <img 
                src={featuredPost.data.image} 
                alt={featuredPost.data.title}
                class="w-full h-full object-cover transition-transform duration-1000 group-hover:scale-105"
              />
            </div>
            <div class="w-full lg:w-2/5">
              <span class="bg-black text-white px-3 py-1 text-[9px] font-black uppercase tracking-widest mb-6 inline-block italic">Destacado</span>
              <h2 class="text-4xl md:text-5xl font-black uppercase italic text-gray-900 leading-[0.9] mb-6 group-hover:text-[#36AAF5] transition-colors tracking-tighter">
                {featuredPost.data.title}
              </h2>
              <p class="text-gray-500 text-lg font-medium leading-relaxed mb-8">
                {featuredPost.data.excerpt}
              </p>
              <div class="flex items-center gap-3 text-xs font-black uppercase italic tracking-widest text-gray-900">
                Leer artículo <span class="text-[#38F5C4] group-hover:translate-x-3 transition-transform font-bold text-xl">→</span>
              </div>
            </div>
          </div>
        </div>
      </section>
    )}

    <section class="py-5 px-6" id="grid-section">
      <div class="max-w-7xl mx-auto">
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-10">
          {remainingPosts.map((post) => (
            <article class="blogs-card group relative flex flex-col p-4 rounded-lg transition-all duration-500 bg-white border border-gray-100 hover:bg-white hover:border-[#38F5C4]/30 hover:shadow-xl">
              <a href={`/blogs/${post.slug}`} class="absolute inset-0 z-30" aria-label={post.data.title}></a>

              <div class="overflow-hidden rounded-lg mb-8 relative aspect-16/11 shadow-sm">
                <img 
                  src={post.data.image} 
                  alt={post.data.title}
                  class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110"
                />
                <div class="absolute top-5 left-5 z-10">
                   <span class="bg-white px-4 py-1.5 rounded-full text-[9px] font-black uppercase tracking-widest text-gray-900 italic shadow-sm border border-gray-100">
                    {post.data.category}
                   </span>
                </div>
              </div>
              
              <div class="px-2 pb-4">
                <time class="text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-4 block italic">
                  {post.data.date.toLocaleDateString('es-ES', { day: '2-digit', month: 'short', year: 'numeric' })}
                </time>
                <h3 class="text-2xl font-black uppercase italic text-gray-900 leading-[1.1] mb-4 tracking-tighter group-hover:text-[#36AAF5] transition-colors">
                  {post.data.title}
                </h3>
                <p class="text-gray-500 text-sm font-medium leading-relaxed line-clamp-2">
                  {post.data.excerpt}
                </p>
                <div class="mt-8 h-0.5 w-12 bg-gray-100 group-hover:w-full group-hover:bg-[#38F5C4] transition-all duration-500"></div>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>

  </main>
</Layout>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";
  gsap.registerPlugin(ScrollTrigger);

  // Animación del Header
  gsap.from(".reveal-header", { x: -30, opacity: 0, duration: 0.8 });
  gsap.from(".reveal-header-right", { x: 30, opacity: 0, duration: 0.8 });

  // Animación del grid (Aseguramos que la opacidad final sea 1)
  gsap.from(".blogs-card", {
    scrollTrigger: {
      trigger: "#grid-section",
      start: "top 85%",
    },
    y: 30,
    opacity: 0,
    duration: 0.6,
    stagger: 0.1,
    clearProps: "opacity", // ESTO ELIMINA EL ATRIBUTO OPACITY AL TERMINAR LA ANIMACIÓN
    ease: "power2.out"
  });
</script>