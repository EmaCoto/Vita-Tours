---

import FeaturedTours from '../components/Home/FeaturedTours.astro';
import ScrollVideoStory from '../components/Home/ScrollVideoStory';
import TransformationRoute from '../components/Home/TransformationRoute.astro';
import PsychologicalBenefits from '../components/Home/PsychologicalBenefits.astro';
import TestimonialsImpact from '../components/Home/TestimonialsImpact.astro';
import SectionBlog from '../components/Home/SectionBlog.astro';
import Layout from '../layouts/Layout.astro';

interface Props {
    title: string;
    description?: string; // La hacemos opcional con el "?"
}

// Definimos un valor por defecto por si se te olvida ponerla en alguna página
const { 
	title = "Vita Tours Medellín | Caminatas conscientes + psicología",
	description = "Tours caminando en Medellín por senderos, ríos y lagos, con psicología práctica en ruta (ansiedad, estrés, bienestar). Experiencia segura y única. Reserva."
} = Astro.props;
---

<Layout title={title} description={description}>

	<ScrollVideoStory client:load />
	<FeaturedTours />
	<TransformationRoute />
	<PsychologicalBenefits/>
	<TestimonialsImpact />
	<SectionBlog />
</Layout>
