---
const pasos = [
  { n: "01", t: "Encuentro", d: "Punto de reunión en la naturaleza de Medellín." },
  { n: "02", t: "Caminata Consciente", d: "Senderos que activan tus cinco sentidos." },
  { n: "03", t: "Círculo de Palabra", d: "Psicología aplicada sin juicios ni etiquetas." },
  { n: "04", t: "Regreso Renovado", d: "Vuelves a la ciudad con nuevas herramientas." }
];
---

<section class="py-10 bg-white overflow-hidden" id="ruta-section">
  <div class="max-w-6xl mx-auto px-6">
    <div class="text-center mb-20">
      <span class="text-[#36AAF5] font-black uppercase tracking-[0.4em] text-[10px] block mb-4">Metodología Vita</span>
      <h2 class="text-4xl md:text-6xl font-black uppercase italic text-gray-900 tracking-tighter">La Ruta de la <span class="text-[#38F5C4]">Transformación</span></h2>
    </div>

    <div class="relative grid grid-cols-1 md:grid-cols-4 gap-12">
      <div class="hidden md:block absolute top-12 left-0 w-full h-[2px] bg-gray-100 z-0">
        <div id="progress-line" class="h-full bg-[#38F5C4] w-0"></div>
      </div>

      {pasos.map((paso) => (
        <div class="paso-card relative z-10 flex flex-col items-center text-center">
          <div class="w-24 h-24 bg-white border-2 border-gray-100 rounded-2xl flex items-center justify-center mb-6 transition-all duration-500 step-icon shadow-sm">
            <span class="text-3xl font-black italic text-gray-200 step-number">{paso.n}</span>
          </div>
          <h3 class="text-xl font-black uppercase italic text-gray-900 mb-3">{paso.t}</h3>
          <p class="text-gray-500 text-sm leading-relaxed">{paso.d}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";
  gsap.registerPlugin(ScrollTrigger);

  // Animación de la línea y los pasos
  const tl = gsap.timeline({
    scrollTrigger: {
      trigger: "#ruta-section",
      start: "top 70%",
      end: "top 20%",
      scrub: 1,
    }
  });

  tl.to("#progress-line", { w: "100%", duration: 2 })
    .to(".step-icon", { borderColor: "#38F5C4", scale: 1.1, stagger: 0.5 }, 0)
    .to(".step-number", { color: "#38F5C4", stagger: 0.5 }, 0);
</script>

<style>
  /* Personalización extra para que se vea moderno */
  .paso-card:hover .step-icon {
    box-shadow: 0 20px 40px -10px rgba(56, 245, 196, 0.3);
    transform: translateY(-10px);
  }
</style>