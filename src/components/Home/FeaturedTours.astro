---
import { getCollection } from 'astro:content';
const tours = await getCollection('tours');
---

<section class="bg-white pt-16 pb-10 md:py-22 overflow-hidden relative z-99 -mt-10 rounded-t-[40px]">
  <div class="max-w-7xl mx-auto px-4">
    
    <div class="flex flex-col md:flex-row justify-between items-center md:mb-10 gap-8">
      <div>
        <span class="text-[#38F5C4] font-bold text-[10px] uppercase tracking-[0.4em] block mb-2 text-center md:text-left">Explora el catálogo</span>
        <h2 class="text-3xl font-black text-gray-900 uppercase italic leading-none text-center md:text-left tracking-tighter">Rutas Activas</h2>
      </div>

      <div class="flex md:hidden items-center gap-6 bg-gray-100 p-2 rounded-full shadow-md border border-gray-200">
        <button id="prevBtnMob" class="group p-4 bg-white rounded-full shadow-sm active:scale-95 transition-all cursor-pointer">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" class="text-gray-400"><path d="M15 18l-6-6 6-6"/></svg>
        </button>
        <div class="text-center min-w-20">
          <span class="counter-text text-xs font-black text-gray-900 uppercase italic tracking-tighter">01 / {tours.length.toString().padStart(2, '0')}</span>
        </div>
        <button id="nextBtnMob" class="group p-4 bg-white rounded-full shadow-sm active:scale-95 transition-all cursor-pointer">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" class="text-gray-400"><path d="M9 5l6 6-6 6"/></svg>
        </button>
      </div>
    </div>

    <div class="relative min-h-112.5 md:min-h-120 flex items-center justify-center">
      
      <button id="prevBtn" class="hidden md:flex absolute left-0 z-50 group p-5 bg-gray-200 rounded-full shadow-xl border border-gray-100 hover:bg-black transition-all duration-300 cursor-pointer hover:-translate-x-2">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" class="group-hover:text-[#38F5C4] text-gray-400 transition-colors">
          <path d="M15 18l-6-6 6-6"/>
        </svg>
      </button>

      <div id="stack-container" class="relative w-full max-w-250 h-80 cursor-grab active:cursor-grabbing touch-none">
        {tours.map((tour, index) => (
          <div class="tour-card absolute top-0 w-full transition-all duration-700" data-index={index}>
            <a href={`/tours/${tour.slug}`} class="block h-80 w-full pointer-events-none md:pointer-events-auto">
              <div class="relative h-full w-full rounded-2xl overflow-hidden shadow-2xl border border-gray-100 bg-black">
                <img src={tour.data.imagen} class="absolute inset-0 w-full h-full object-cover opacity-70" alt={tour.data.nombre} draggable="false" />
                <div class="absolute inset-0 bg-linear-to-t from-black via-black/20 to-transparent"></div>
                <div class="absolute bottom-0 left-0 p-6 md:p-8 w-full">
                  <span class="bg-[#38F5C4] text-black text-[9px] font-black uppercase tracking-widest px-2 py-1 rounded-sm mb-4 inline-block">{tour.data.tag}</span>
                  <h3 class="text-white text-2xl md:text-3xl font-black uppercase italic leading-tight mb-2 tracking-tighter">{tour.data.nombre}</h3>
                  <p class="text-white/60 text-[10px] font-bold uppercase tracking-widest">{tour.data.duracion} • {tour.data.lugarDestino}</p>
                </div>
              </div>
            </a>
          </div>
        ))}
      </div>

      <button id="nextBtn" class="hidden md:flex absolute right-0 z-50 group p-5 bg-gray-200 rounded-full shadow-xl border border-gray-100 hover:bg-black transition-all duration-300 cursor-pointer hover:translate-x-2">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" class="group-hover:text-[#38F5C4] text-gray-400 transition-colors">
          <path d="M9 5l6 6-6 6"/>
        </svg>
      </button>

    </div>
  </div>
</section>

<script>
  const container = document.getElementById('stack-container');
  const cards = document.querySelectorAll('.tour-card');
  const counterTexts = document.querySelectorAll('.counter-text');
  
  // Seleccionamos ambos pares de botones
  const nextBtns = [document.getElementById('nextBtn'), document.getElementById('nextBtnMob')];
  const prevBtns = [document.getElementById('prevBtn'), document.getElementById('prevBtnMob')];
  
  let currentIndex = 0;
  let startX = 0;
  let isDragging = false;

  function updateStack() {
    const isMobile = window.innerWidth < 768;

    cards.forEach((card, i) => {
      const htmlCard = card as HTMLElement;
      const distance = i - currentIndex;
      
      if (isMobile) {
        if (distance === 0) {
          htmlCard.style.transform = `translateX(0) translateY(0) scale(1) translateZ(0)`;
          htmlCard.style.opacity = '1';
          htmlCard.style.zIndex = '40';
          htmlCard.style.filter = 'blur(0px)';
          htmlCard.style.visibility = 'visible';
        } else if (distance > 0 && distance <= 3) {
          const yOffset = distance * -15; 
          const scale = 1 - (distance * 0.06);
          const zOffset = distance * -40;
          htmlCard.style.transform = `translateX(0) translateY(${yOffset}px) scale(${scale}) translateZ(${zOffset}px)`;
          htmlCard.style.opacity = (0.5 / distance).toString();
          htmlCard.style.zIndex = (30 - distance).toString();
          htmlCard.style.filter = 'blur(2px) brightness(0.8)';
          htmlCard.style.visibility = 'visible';
        } else {
          const side = distance < 0 ? -100 : 100;
          htmlCard.style.transform = `translateX(${side}%) scale(0.5)`;
          htmlCard.style.opacity = '0';
          htmlCard.style.zIndex = '0';
          htmlCard.style.visibility = 'hidden';
        }
      } else {
        const isFocused = (i === currentIndex || i === currentIndex + 1);
        htmlCard.style.visibility = 'visible';
        if (isFocused) {
          const sideOffset = (i === currentIndex) ? -240 : 240;
          htmlCard.style.transform = `translateX(${sideOffset}px) scale(1) translateZ(0) rotateY(0)`;
          htmlCard.style.opacity = '1';
          htmlCard.style.zIndex = '30';
          htmlCard.style.filter = 'blur(0px)';
        } else {
          const side = distance > 0 ? 1 : -1;
          const absDistance = Math.abs(distance);
          const xBase = side > 0 ? 380 : -380;
          const xOffset = xBase + (side * (absDistance * 80));
          const zOffset = absDistance * -200;
          const scale = 0.8 - (absDistance * 0.05);
          const rotate = side * -15;
          htmlCard.style.transform = `translateX(${xOffset}px) translateZ(${zOffset}px) scale(${scale}) rotateY(${rotate}deg)`;
          htmlCard.style.opacity = '0.3';
          htmlCard.style.zIndex = '10';
          htmlCard.style.filter = 'blur(4px)';
        }
      }
    });

    counterTexts.forEach(el => {
      el.textContent = `${(currentIndex + 1).toString().padStart(2, '0')} / ${cards.length.toString().padStart(2, '0')}`;
    });
  }

  const goNext = () => {
    const isMobile = window.innerWidth < 768;
    const limit = isMobile ? cards.length - 1 : cards.length - 2;
    currentIndex = (currentIndex < limit) ? currentIndex + 1 : 0;
    updateStack();
  };

  const goPrev = () => {
    const isMobile = window.innerWidth < 768;
    if (currentIndex > 0) currentIndex--; 
    else currentIndex = cards.length - (isMobile ? 1 : 2);
    updateStack();
  };

  nextBtns.forEach(btn => btn?.addEventListener('click', goNext));
  prevBtns.forEach(btn => btn?.addEventListener('click', goPrev));

  const handleStart = (x: number) => { startX = x; isDragging = true; };
  const handleMove = (x: number) => {
    if (!isDragging) return;
    const diff = startX - x;
    if (Math.abs(diff) > 60) {
      if (diff > 0) goNext(); else goPrev();
      isDragging = false;
    }
  };

  container?.addEventListener('mousedown', (e) => handleStart(e.pageX));
  window.addEventListener('mousemove', (e) => handleMove(e.pageX));
  window.addEventListener('mouseup', () => isDragging = false);
  container?.addEventListener('touchstart', (e) => handleStart(e.touches[0].pageX), {passive: true});
  container?.addEventListener('touchmove', (e) => handleMove(e.touches[0].pageX), {passive: true});
  window.addEventListener('touchend', () => isDragging = false);

  window.addEventListener('resize', updateStack);
  updateStack();
</script>

<style>
  #stack-container { perspective: 1200px; transform-style: preserve-3d; }
  .tour-card {
    will-change: transform, opacity;
    left: 50%;
    transform: translateX(-50%);
    transition: all 0.6s cubic-bezier(0.23, 1, 0.32, 1);
  }
  @media (min-width: 768px) { .tour-card { max-width: 450px; margin-left: -225px; } }
  @media (max-width: 767px) { .tour-card { width: 90%; margin-left: -45%; } }
</style>