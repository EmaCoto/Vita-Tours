---
// Blogs.astro
import { getCollection } from 'astro:content';

// 1. Obtenemos la colección de blogs
const allPosts = await getCollection('blogs');

// 2. ORDENAMIENTO POR FECHA (Más recientes primero)
// Comparamos el valor numérico (.valueOf) de las fechas de publicación
const posts = allPosts
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3); // Solo mostramos los 3 últimos en la Home
---

<section class="py-15 bg-white overflow-hidden" id="blogs-home-section">
  <div class="max-w-7xl mx-auto px-6">
    
    <div class="flex flex-col md:flex-row md:items-end justify-between mb-16 gap-6">
      <div class="max-w-2xl reveal-text">
        <span class="text-[#36AAF5] font-black uppercase tracking-[0.4em] text-[10px] block mb-4 italic">Exploración Reciente</span>
        <h2 class="text-5xl md:text-7xl font-black uppercase italic text-gray-900 leading-[0.85] tracking-tighter">
          CIENCIA <br/> <span class="text-[#38F5C4]">& AVENTURA.</span>
        </h2>
      </div>
      <a href="/blogs" class="group flex items-center gap-2 text-xs font-black uppercase tracking-widest italic border-b-2 border-[#38F5C4] pb-1 hover:text-[#36AAF5] transition-all">
        Ver bitácora completa
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" class="group-hover:translate-x-1 transition-transform"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
      </a>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-10">
      {posts.map((post) => (
        <article class="blogs-card group relative flex flex-col bg-white rounded-lg p-4 border border-gray-100 transition-all duration-500 hover:shadow-2xl hover:border-[#38F5C4]/30">
          
          <a href={`/blogs/${post.slug}`} class="absolute inset-0 z-20" aria-label={post.data.title}></a>

          <div class="aspect-[16/10] overflow-hidden rounded-lg mb-8 relative shadow-sm">
            <img 
              src={post.data.image} 
              alt={post.data.title} 
              class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-1000"
            />
            <div class="absolute top-4 left-4 bg-white/95 backdrop-blur-md px-4 rounded-full z-10 border border-gray-50">
              <span class="text-[10px] font-black uppercase tracking-widest text-gray-900 italic">{post.data.category}</span>
            </div>
          </div>

          <div class="px-2 pb-4">
            <time class="text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-3 block italic">
              {post.data.date.toLocaleDateString('es-ES', { day: '2-digit', month: 'short', year: 'numeric' })}
            </time>
            <h3 class="text-2xl font-black uppercase italic text-gray-900 leading-[1.1] mb-4 tracking-tighter group-hover:text-[#36AAF5] transition-colors">
              {post.data.title}
            </h3>
            <p class="text-gray-500 text-sm font-medium leading-relaxed mb-6 line-clamp-2">
              {post.data.excerpt}
            </p>
            
            <div class="mt-auto flex items-center gap-2 text-[10px] font-black uppercase italic tracking-widest group-hover:gap-4 transition-all">
              Leer más <span class="text-[#38F5C4] font-bold text-lg">→</span>
            </div>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";
  gsap.registerPlugin(ScrollTrigger);

  // Animación GSAP limpia (Sin problemas de opacidad)
  gsap.from(".blogs-card", {
    scrollTrigger: {
      trigger: "#blogs-home-section",
      start: "top 75%",
    },
    y: 40,
    opacity: 0,
    duration: 0.8,
    stagger: 0.15,
    clearProps: "all", // Limpia estilos de GSAP al terminar para opacidad 100%
    ease: "power2.out"
  });
</script>