---
// Navbar.astro
// Identidad Vita Tours: 60% Blanco, 15% Turquesa, 10% Azul Cielo
---

<nav class="fixed top-0 left-0 w-full z-9999 px-4 md:px-2 py-6">
  <div class="relative max-w-7xl mx-auto h-16 bg-white backdrop-blur-sm rounded-lg flex items-center justify-between px-3 shadow-lg">
    
    <div class="flex items-center gap-5 w-1/3">
      <div class="flex gap-4 text-[#36AAF5]">
        <a href="#" class="hover:text-[#38F5C4] transition-colors">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line></svg>
        </a>
        <a href="#" class="hover:text-[#38F5C4] transition-colors">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path></svg>
        </a>
        <a href="#" class="hover:text-[#38F5C4] transition-colors">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 12a4 4 0 1 0 4 4V4a5 5 0 0 0 5 5"></path></svg>
        </a>
      </div>
      <span class="hidden lg:block text-[#36AAF5] text-[11px] font-bold tracking-widest border-l border-[#36AAF5]/20 pl-4">
        +57 300 000 0000
      </span>
    </div>

    <div class="flex items-center justify-center w-1/3">
      <div class="hidden md:flex gap-8 mr-20">
        <a href="/" class="text-[#36AAF5] text-xs font-bold hover:text-[#38F5C4] transition-colors uppercase tracking-[0.2em]">
          Home
        </a>
        <a href="/tours" class="text-[#36AAF5] text-xs font-bold hover:text-[#38F5C4] transition-colors uppercase tracking-[0.2em]">
          Tours
        </a>
      </div>

      <div class="absolute left-1/2 -translate-x-1/2 top-1/2 -translate-y-1/2">
        <div class="relative group">
          <a href="/" class="w-24 h-24 bg-white border border-[#36AAF5] rounded-full flex items-center justify-center shadow-lg transition-transform group-hover:scale-105">
            <img src="/img/logo-vitatours.png" 
              alt="Vita Tours" 
              class="w-22 h-auto"
            />
          </a>
        </div>
      </div>

      <div class="hidden md:flex gap-8 ml-32">
        <a href="/contact" class="text-[#36AAF5] text-xs font-bold hover:text-[#38F5C4] transition-colors uppercase tracking-[0.2em]">
          Contact
        </a>
        <a href="/contact" class="text-[#36AAF5] text-xs font-bold hover:text-[#38F5C4] transition-colors uppercase tracking-[0.2em]">
          Contact
        </a>
      </div>
    </div>

    <div class="flex justify-end w-1/3">
      <button class="bg-[#36AAF5] hover:bg-[#38F5C4] text-white text-[10px] md:text-xs font-black px-6 py-2.5 rounded-lg transition-all uppercase tracking-widest active:scale-95">
        Vivir experiencia
      </button>
    </div>
  </div>
  
</nav>